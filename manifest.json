{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "version": "1.0",
  "permissions": ["storage", "clipboardWrite"],
  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "exclude_matches": [
      "*://chatgpt.com/*",
      "*://*.google.com/*",
      "*://*.facebook.com/*"
    ],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_end"
  }
]
}